source "https://rubygems.org"

# GitHub Pages-compatible Jekyll stack. The github-pages gem pins Jekyll and
# all plugins to the exact versions that GitHub Pages runs, so what you see
# locally matches what gets deployed.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

gem "webrick", "~> 1.8"
